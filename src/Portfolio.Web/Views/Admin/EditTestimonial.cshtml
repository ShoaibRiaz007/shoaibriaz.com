@model Testimonial
@{
    ViewData["Title"] = Model.Id == 0 ? "Add Testimonial" : "Edit Testimonial";
}
<div class="admin-card" style="max-width:640px;">
    <div class="card-head"><h2>@ViewData["Title"]</h2><a class="admin-link" asp-action="Index">← Back</a></div>
    <form asp-action="EditTestimonial" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Author" class="form-label"></label>
                <input asp-for="Author" class="form-control" />
                <span asp-validation-for="Author" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="AuthorTitle" class="form-label"></label>
                <input asp-for="AuthorTitle" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="Quote" class="form-label"></label>
                <textarea asp-for="Quote" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Quote" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="SortOrder" class="form-label"></label>
                <input asp-for="SortOrder" class="form-control" />
            </div>
        </div>
        <div class="mt-4">
            <button type="submit" class="btn btn-accent">Save</button>
            <a class="btn btn-outline-light" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
