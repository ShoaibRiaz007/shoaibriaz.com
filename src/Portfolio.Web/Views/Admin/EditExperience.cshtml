@model Experience
@{
    ViewData["Title"] = Model.Id == 0 ? "Add Experience" : "Edit Experience";
}
<div class="admin-card" style="max-width:760px;">
    <div class="card-head"><h2>@ViewData["Title"]</h2><a class="admin-link" asp-action="Index">← Back</a></div>
    <form asp-action="EditExperience" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Role" class="form-label"></label>
                <input asp-for="Role" class="form-control" />
                <span asp-validation-for="Role" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Company" class="form-label"></label>
                <input asp-for="Company" class="form-control" />
                <span asp-validation-for="Company" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="EmploymentType" class="form-label"></label>
                <input asp-for="EmploymentType" class="form-control" placeholder="Full-time" />
            </div>
            <div class="col-md-6">
                <label asp-for="Period" class="form-label"></label>
                <input asp-for="Period" class="form-control" placeholder="Nov 2023 - May 2026" />
            </div>
            <div class="col-12">
                <label asp-for="Location" class="form-label"></label>
                <input asp-for="Location" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                <div class="small text-dim">One bullet point per line.</div>
            </div>
            <div class="col-md-4">
                <label asp-for="SortOrder" class="form-label"></label>
                <input asp-for="SortOrder" class="form-control" />
            </div>
        </div>
        <div class="mt-4">
            <button type="submit" class="btn btn-accent">Save</button>
            <a class="btn btn-outline-light" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
