@model ProjectsViewModel
@{
    Layout = null;
    var projects = Model.Projects;
    var bio = Model.Bio;
    var categories = Model.Categories;
    var name = string.IsNullOrWhiteSpace(bio.FullName) ? "Portfolio" : bio.FullName;
    Func<Project, string> Slug = p => string.IsNullOrWhiteSpace(p.Slug) ? p.Id.ToString() : p.Slug;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>All Projects — @name</title>
    <meta name="description" content="The full portfolio of @name — games, packages, AR/VR, and backend systems." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/portfolio.css" asp-append-version="true" />
</head>
<body>
    <div class="bg-glow"></div>

    <header class="nav">
        <div class="container inner">
            <a href="/" class="brand">@name.Split(' ')[0]<span class="dot">.</span></a>
            <nav class="nav-links">
                <a href="/#about">About</a>
                <a href="/#services">Services</a>
                <a href="/projects">Projects</a>
                <a href="/#skills">Skills</a>
                <a href="/#contact" class="nav-cta">Get in touch</a>
            </nav>
        </div>
    </header>

    <main>
        <section class="page-head">
            <div class="container">
                <div class="breadcrumb-nav"><a href="/">Home</a> &nbsp;/&nbsp; Projects</div>
                <span class="eyebrow">Portfolio</span>
                <h1 class="cs-title">All projects</h1>
                <p class="cs-summary">@projects.Count projects across games, AR/VR, packages, and backend systems. Search or filter by category.</p>

                <div class="filter-bar">
                    <div class="search-box">
                        <span class="ico">🔎</span>
                        <input type="text" id="searchInput" placeholder="Search projects, tech, keywords…" autocomplete="off" />
                    </div>
                    <div class="cat-filters" id="catFilters">
                        <button class="cat-btn active" data-cat="all">All</button>
                        @foreach (var c in categories)
                        {
                            <button class="cat-btn" data-cat="@c.ToLower()">@c</button>
                        }
                    </div>
                </div>
            </div>
        </section>

        <section style="padding-top:0;">
            <div class="container">
                <div class="result-count" id="resultCount"></div>
                <div class="grid grid-3" id="projectGrid">
                    @foreach (var p in projects)
                    {
                        var haystack = $"{p.Title} {p.Summary} {p.Description} {p.Category} {p.TechStack}".ToLower();
                        <div class="card project-card" data-category="@(p.Category?.ToLower())" data-search="@haystack">
                            <a href="/project/@Slug(p)" class="project-thumb" style="text-decoration:none;color:inherit;">
                                @if (!string.IsNullOrWhiteSpace(p.ImageUrl)) { <img src="@p.ImageUrl" alt="@p.Title" loading="lazy" /> }
                                else { <span>🎮</span> }
                                @if (!string.IsNullOrWhiteSpace(p.Category)) { <span class="project-cat">@p.Category</span> }
                                @if (p.IsFeatured) { <span class="project-cat" style="left:auto;right:14px;background:var(--grad);color:#06060c;">★ Featured</span> }
                            </a>
                            <div class="project-body">
                                <h3><a href="/project/@Slug(p)" style="text-decoration:none;color:inherit;">@p.Title</a></h3>
                                <p>@(string.IsNullOrWhiteSpace(p.Summary) ? p.Description : p.Summary)</p>
                                @if (!string.IsNullOrWhiteSpace(p.TechStack))
                                {
                                    <div class="tech-tags">
                                        @foreach (var t in p.TechStack.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <span>@t.Trim()</span>
                                        }
                                    </div>
                                }
                                <div class="project-links">
                                    <a href="/project/@Slug(p)">Case study →</a>
                                    @if (!string.IsNullOrWhiteSpace(p.ProjectUrl)) { <a href="@p.ProjectUrl" target="_blank">Live ↗</a> }
                                    @if (!string.IsNullOrWhiteSpace(p.GitHubUrl)) { <a href="@p.GitHubUrl" target="_blank">Code ↗</a> }
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="no-results" id="noResults">No projects match your search. Try a different keyword or category.</div>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container inner">
            <div>© @DateTime.Now.Year @name. All rights reserved.</div>
            <div><a href="/">← Back to home</a></div>
        </div>
    </footer>

    <script src="~/js/projects-filter.js" asp-append-version="true"></script>
</body>
</html>
